# ============================================
# CONFIGURAZIONE SERVER
# ============================================
PORT=3000

# ============================================
# CONFIGURAZIONE SMTP (es. Gmail, Aruba, Register.it, Zoho...)
# ============================================
# Esempio Gmail: usa una "Password per le App" (non la password normale)
# Esempio Aruba: smtp.aruba.it / porta 465 / secure true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=tuonome@gmail.com
SMTP_PASS=la_tua_password_app

# Mittente che comparirà nelle email inviate
MAIL_FROM_NAME=Nooo Agency - Sito Web
MAIL_FROM_EMAIL=tuonome@gmail.com

# Destinatario/i che riceveranno le richieste dal form (separati da virgola)
MAIL_TO=destinatario@noooagency.com,tuaemail@gmail.com

# ============================================
# CORS - dominio del frontend (per produzione)
# ============================================
CORS_ORIGIN=*
